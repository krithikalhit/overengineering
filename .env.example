# --- Auth ---
# Long random string. Used to sign the admin session cookie.
AUTH_SECRET=change-me-to-a-long-random-string
# Single shared password for the /admin dashboard.
ADMIN_PASSWORD=change-me

# --- Google Sheets ---
# Spreadsheet ID (the long ID in the sheet URL).
GOOGLE_SHEET_ID=
# Service account email.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Service account private key. Paste the full PEM string;
# escape newlines as \n if storing in a single line (Vercel does this for you).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Runway (Google OAuth + master financial sheet) ---
# OAuth client from Google Cloud Console (Google Auth platform → Clients).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Signs the NextAuth session JWT. Run: openssl rand -base64 32
NEXTAUTH_SECRET=
# http://localhost:3000 locally; the prod URL on Vercel.
NEXTAUTH_URL=http://localhost:3000
# The master financial spreadsheet (long ID in the sheet URL). This is NOT the
# CRM sheet above — Runway reads/writes it with the signed-in user's account.
SPREADSHEET_ID=
# Optional: pin the main tab name. If unset, the app auto-detects the tab whose
# column A contains the category labels from lib/runway/sheetMap.ts.
RUNWAY_SHEET_TAB=

# --- Google Calendar (Meetings) ---
# Calendar ID. "primary" reads the calendar belonging to the service account
# (not what you want). Use the user's calendar ID (e.g. you@yourdomain.com)
# and share that calendar with the service account email as "See all event details".
GOOGLE_CALENDAR_ID=primary
