# --- Auth ---
# Long random string. Used to sign the admin session cookie.
AUTH_SECRET=change-me-to-a-long-random-string
# Single shared password for the /admin dashboard.
ADMIN_PASSWORD=change-me

# --- Google Sheets ---
# Spreadsheet ID (the long ID in the sheet URL).
GOOGLE_SHEET_ID=
# Service account email.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Service account private key. Paste the full PEM string;
# escape newlines as \n if storing in a single line (Vercel does this for you).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Google Calendar (Meetings) ---
# Calendar ID. "primary" reads the calendar belonging to the service account
# (not what you want). Use the user's calendar ID (e.g. you@yourdomain.com)
# and share that calendar with the service account email as "See all event details".
GOOGLE_CALENDAR_ID=primary
